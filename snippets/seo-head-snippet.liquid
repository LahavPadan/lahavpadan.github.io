{%- comment -%}
Paste this inside <head>, preferably right before </head>.

Before adding it, remove old manually-written:
- <title>...</title>
- <meta name="description" ...>
- <link rel="canonical" ...>

Keep your stylesheet links, viewport meta tag, MathJax, and scripts.
{%- endcomment -%}

{% seo %}

{% if site.google_site_verification and site.google_site_verification != "PASTE_GOOGLE_VERIFICATION_TOKEN_HERE" %}
  <meta
    name="google-site-verification"
    content="{{ site.google_site_verification }}"
  >
{% endif %}
